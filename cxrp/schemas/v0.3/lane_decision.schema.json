{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LaneDecision",
  "type": "object",
  "required": ["schema_version", "contract_kind", "decision_id", "proposal_id", "metadata", "lane"],
  "properties": {
    "schema_version": {"const": "0.3"},
    "contract_kind": {"const": "lane_decision"},
    "decision_id": {"type": "string"},
    "proposal_id": {"type": "string"},
    "created_at": {"type": ["string", "null"], "format": "date-time"},
    "metadata": {"type": "object"},
    "lane": {"type": "string", "enum": ["coding_agent", "review_agent", "local_model", "hosted_model", "aider_local"]},
    "executor": {"type": ["string", "null"], "enum": ["claude_cli", "codex_cli", "aider_local", null]},
    "backend": {"type": ["string", "null"], "enum": ["direct_local", "aider_local", "kodo", "archon", "archon_then_kodo", "openclaw", null]},
    "rationale": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lane"],
        "properties": {
          "lane": {"type": "string", "enum": ["coding_agent", "review_agent", "local_model", "hosted_model", "aider_local"]},
          "executor": {"type": ["string", "null"], "enum": ["claude_cli", "codex_cli", "aider_local", null]},
          "backend": {"type": ["string", "null"], "enum": ["direct_local", "aider_local", "kodo", "archon", "archon_then_kodo", "openclaw", null]},
          "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "execution_target": {
      "type": ["object", "null"],
      "properties": {
        "lane": {"type": "string", "enum": ["coding_agent", "review_agent", "local_model", "hosted_model", "aider_local"]},
        "backend": {"type": ["string", "null"], "enum": ["direct_local", "aider_local", "kodo", "archon", "archon_then_kodo", "openclaw", null]},
        "executor": {"type": ["string", "null"], "enum": ["claude_cli", "codex_cli", "aider_local", null]},
        "runtime_binding": {"type": ["object", "null"]}
      },
      "required": ["lane"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
